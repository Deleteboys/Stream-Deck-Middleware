{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "streamdeckmiddleware",
  "version": "0.2.2",
  "identifier": "com.streamdeckmiddleware.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StreamDeck Settings",
        "width": 1280,
        "height": 720,
        "label": "main",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCMUJDODUwQUFENjNDNjgKUldSb1BOYXFVTWdiYTdFQmZMVnI0NWJMc2kwZ2dXQXpiU09pREkrZWdidlB6Y2U0aXl3KzE4bjEK",
      "endpoints": [
        "https://github.com/Deleteboys/Stream-Deck-Middleware/releases/latest/download/latest.json"
      ]
    }
  }
}